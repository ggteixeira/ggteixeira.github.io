---
import { SITE, LINKS } from "@consts";
import { cn } from "@lib/utils";
import { useTranslations, getOtherLocaleUrl } from "@i18n/utils";
const { pathname } = Astro.url;
const subpath = pathname.match(/[^/]+/g);

const t = useTranslations(Astro.currentLocale);
const switchUrl = getOtherLocaleUrl(pathname, Astro.currentLocale ?? "en");

const navTranslations: Record<string, string> = {
  "/": t("nav.home"),
  "/garden": t("nav.garden"),
  "/about": t("nav.about"),
};

const isPtBr = Astro.currentLocale === "pt-br";
const linkHrefPrefix = isPtBr ? "/pt-br" : "";
---

<div
  id="drawer"
  class="fixed inset-0 h-0 z-40 overflow-hidden flex flex-col items-center justify-center md:hidden bg-neutral-100 dark:bg-neutral-900 transition-[height] duration-300 ease-in-out"
>
  <nav class="flex flex-col items-center space-y-2">
    {
      LINKS.map((LINK) => {
        const localizedHref = linkHrefPrefix + LINK.HREF;
        const isActive =
          pathname === localizedHref ||
          "/" + subpath?.[0] === LINK.HREF ||
          (isPtBr &&
            ("/" + subpath?.[1] === LINK.HREF ||
              pathname === "/pt-br" + LINK.HREF));
        return (
          <a
            href={localizedHref}
            class={cn(
              "flex items-center justify-center px-3 py-1 rounded-full",
              "text-current hover:text-black dark:hover:text-white",
              "hover:bg-black/5 dark:hover:bg-white/20",
              "transition-colors duration-300 ease-in-out",
              isActive
                ? "pointer-events-none bg-black dark:bg-white text-white dark:text-black"
                : "",
            )}
          >
            {navTranslations[LINK.HREF] ?? LINK.TEXT}
          </a>
        );
      })
    }
  </nav>

  <div class="flex gap-1 mt-5">
    <a
      href={isPtBr ? "/pt-br/search" : "/search"}
      aria-label={`Search garden posts and projects on ${SITE.TITLE}`}
      class={cn(
        "size-9 rounded-full p-2 items-center justify-center bg-transparent hover:bg-black/5 dark:hover:bg-white/20 stroke-current hover:stroke-black hover:dark:stroke-white border border-black/10 dark:border-white/25 transition-colors duration-300 ease-in-out",
        pathname === "/search" ||
          pathname === "/pt-br/search" ||
          "/" + subpath?.[0] === "search"
          ? "pointer-events-none bg-black dark:bg-white text-white dark:text-black"
          : "",
      )}
    >
      <svg class="size-full">
        <use href="/ui.svg#search"></use>
      </svg>
    </a>

    <a
      href="/rss.xml"
      target="_blank"
      aria-label={`Rss feed for ${SITE.TITLE}`}
      class="size-9 rounded-full p-2 items-center justify-center bg-transparent hover:bg-black/5 dark:hover:bg-white/20 stroke-current hover:stroke-black hover:dark:stroke-white border border-black/10 dark:border-white/25 transition-colors duration-300 ease-in-out"
    >
      <svg class="size-full">
        <use href="/ui.svg#rss"></use>
      </svg>
    </a>

    <button
      id="drawer-theme-button"
      aria-label={`Toggle light and dark theme`}
      class="size-9 rounded-full p-2 items-center justify-center bg-transparent hover:bg-black/5 dark:hover:bg-white/20 stroke-current hover:stroke-black hover:dark:stroke-white border border-black/10 dark:border-white/25 transition-colors duration-300 ease-in-out"
    >
      <svg class="block dark:hidden size-full">
        <use href="/ui.svg#sun"></use>
      </svg>
      <svg class="hidden dark:block size-full">
        <use href="/ui.svg#moon"></use>
      </svg>
    </button>

    <a
      href={switchUrl}
      data-lang-switch
      class={cn(
        "flex items-center w-20 h-9 rounded-full p-0.5",
        "border border-black/10 dark:border-white/25",
        isPtBr ? "justify-end" : "justify-start",
      )}
    >
      <span
        class="flex items-center justify-center px-2.5 h-full rounded-full bg-black dark:bg-white text-white dark:text-black text-xs font-semibold transition-transform duration-200 ease-in-out"
      >
        {isPtBr ? "pt-br" : "en-us"}
      </span>
    </a>
  </div>
</div>

<style>
  #drawer.open {
    @apply h-full;
  }
</style>
