---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import Search from "@components/Search";
import { useTranslations } from "@i18n/utils";

const posts = (await getCollection("garden")).filter(
  (post) => !post.data.draft,
);

const projects = (await getCollection("projects")).filter(
  (post) => !post.data.draft,
);

const data = [...posts, ...projects] as CollectionEntry<"garden">[];

const t = useTranslations("pt-br");
const searchStrings = {
  placeholder: t("search.placeholder"),
  results: t("search.results"),
};
---

<PageLayout
  title="Busca"
  description="Busque todos os posts e projetos por palavra-chave."
>
  <TopLayout>
    <div class="animate page-heading">Busca</div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <Search client:load data={data} strings={searchStrings} />
    </div>
  </BottomLayout>
</PageLayout>
