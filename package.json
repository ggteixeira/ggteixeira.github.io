{
  "name": "astro-sphere",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "BROWSER=firefox astro dev --open",
    "dev:network": "astro dev --host",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "preview:network": "astro preview --host",
    "astro": "astro",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/content/garden/**/*.md": [
      "node scripts/validate-garden.mjs"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.astro": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/solid-js": "^6.0.0",
    "@astrojs/tailwind": "^6.0.2",
    "@iconify-json/lucide": "^1.2.97",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^6.2.1",
    "astro-icon": "^1.1.5",
    "clsx": "^2.1.0",
    "fuse.js": "^7.1.0",
    "markdown-it": "^14.1.1",
    "sanitize-html": "^2.15.0",
    "sharp": "^0.33.2",
    "solid-js": "^1.9.11",
    "tailwind-merge": "^2.2.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.15.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-solid": "^0.14.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.5.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.5"
  }
}
